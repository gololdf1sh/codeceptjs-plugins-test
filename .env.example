# Required for heal and analyze plugins (AI features)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: @ai-sdk/anthropic reads this automatically.
# If set without /v1 suffix, API calls will fail with 404.
# Either set correctly or leave unset (defaults to https://api.anthropic.com/v1).
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
